NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
BLOCK_DELETE_CODE=1255

# MSG91 login-OTP delivery (Supabase Send SMS hook → MSG91).
# MSG91_AUTH_KEY: MSG91 auth key (secret). Keep IP Security OFF.
# SEND_SMS_HOOK_SECRET: the signing secret Supabase shows when you
#   enable Authentication → Hooks → Send SMS hook (e.g. v1,whsec_...).
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
SEND_SMS_HOOK_SECRET=v1,whsec_YOUR_HOOK_SECRET

# Urgent maintenance-ticket SMS alert to administration (optional).
# Inert unless BOTH are set. Needs a SEPARATE DLT-approved template
# (the OTP template can't be reused). Template vars: var1 = machine,
# var2 = ticket no, var3 = problem.
# MSG91_MAINT_ALERT_TEMPLATE_ID: the approved alert template's MSG91 id.
# MAINTENANCE_ALERT_NUMBERS: comma-separated recipient numbers (e.g. 9198...,9199...).
MSG91_MAINT_ALERT_TEMPLATE_ID=
MAINTENANCE_ALERT_NUMBERS=
